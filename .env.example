# nuclear-eye — Environment Variables
# Copy to .env and adjust. All vars are optional unless noted.

# ── Config ────────────────────────────────────────────────────────────────────
# Path to TOML config file (default: config/security.toml)
HOUSE_SECURITY_CONFIG=config/security.toml

# Logging
RUST_LOG=info

# ── Database / nuclear-wrapper ────────────────────────────────────────────────
# PostgreSQL connection string (used by nuclear-wrapper for heartbeat + failover)
DATABASE_URL=postgres://crew:password@localhost:5432/fortress

# Signal bot token for nuclear-wrapper health alerts (optional)
SIGNAL_TOKEN=your-signal-token-here

# ── Fortress / nuclear-sdk ────────────────────────────────────────────────────
# URL of the Fortress soul engine (default: http://localhost:7700)
FORTRESS_URL=http://localhost:7700

# Fortress API token (required by alarm_grader, safety_aurelie_agent, decision_agent)
FORTRESS_API_TOKEN=your-fortress-api-token-here

# ── Bind addresses ────────────────────────────────────────────────────────────
# Shared bind host for all agents (default: 127.0.0.1; use 0.0.0.0 in Docker)
BIND_HOST=127.0.0.1

# Per-service bind overrides (default derived from BIND_HOST + hardcoded port)
DECISION_AGENT_BIND=127.0.0.1:8085
SAFETY_AURELIE_BIND=127.0.0.1:8086
ACTUATOR_BIND=127.0.0.1:8089
IPHONE_SENSOR_BIND=127.0.0.1:8091
VISION_HEALTH_PORT=8090

# os/56 P1-5 — iphone_sensor_agent HTTP auth (closes os/55 HIGH).
# Bearer token required on POST /sensor/iphone. Unset ⇒ open mode (parity
# with FACE_DB_TOKEN / ALARM_GRADER_FEEDBACK_TOKEN). Generate with:
#   openssl rand -hex 32
# IPHONE_SENSOR_TOKEN=
#
# X-Tenant-Id is forwarded downstream to alarm_grader (Pass 1a/1b: missing
# header resolves to kernel.legacy_default_tenant()). KERNEL_REQUIRE_TENANT_HEADER
# is shared across all kernel agents — declared in the Face DB section below.

# ── Vision agent ──────────────────────────────────────────────────────────────
# RTSP camera URL for direct frame capture (requires opencv feature)
# CAMERA_URL=rtsp://admin:password@192.168.1.100:554/stream

# HTTP JPEG snapshot endpoint (alternative to RTSP)
# CAMERA_SNAPSHOT_URL=http://localhost:5100/snapshot/front-door
# SNAPSHOT_URL=http://localhost:5100/snapshot/front-door

# FastVLM describe endpoint (HTTP sidecar for vision captioning)
FASTVLM_URL=http://localhost:5200
# When fastvlm-service has FASTVLM_API_TOKEN set, use the same value here (vision_agent, main.py HTTP fallback).
# FASTVLM_API_TOKEN=

# FastVLM ONNX model path (default: /data/models/fastvlm/fastvlm.onnx)
FASTVLM_ONNX_PATH=/data/models/fastvlm/fastvlm.onnx

# Set to "true" to disable FastVLM without error (useful in dev)
FASTVLM_DISABLED=false

# Frames per second to grab from RTSP stream (default: 5)
CAMERA_FPS=5

# Allow synthetic/mock vision events in dev mode (default: false)
VISION_ALLOW_SYNTHETIC=false

# ── Face DB ───────────────────────────────────────────────────────────────────
# ArcFace embedding sidecar URL (face_embedding_service.py, default: http://localhost:5555)
ARCFACE_URL=http://localhost:5555
FACE_EMBED_URL=http://localhost:5555

# GDPR retention period in days for face records (default: 30)
FACE_RETENTION_DAYS=30

# os/56 P1-4 — face_db HTTP auth (closes os/55 HIGH).
# Bearer token required on POST /faces, /faces/embed, /faces/purge, /faces/search-by-image,
# GET /faces, /faces/:name, /faces/gdpr-export. When unset, endpoints are open
# (parity with ALARM_GRADER_FEEDBACK_TOKEN). Generate with: openssl rand -hex 32
# FACE_DB_TOKEN=

# os/57 §4.7 multi-tenant rollout — Pass 1c strict mode.
# When 1, missing X-Tenant-Id is rejected with 401. Default 0 = Pass 1a/1b
# (missing header resolves to kernel.legacy_default_tenant()). Flip to 1 only
# after os/58 §2 (Arianne) and §3 (Émile) burn-ins complete.
# KERNEL_REQUIRE_TENANT_HEADER=0

# os/56 P1-4 Pass 2 — Postgres backend symmetric key (used by pgcrypto
# pgp_sym_encrypt to seal biometric embeddings). 32+ bytes recommended.
# Generate with: openssl rand -hex 32
# IMPORTANT: never persist via ALTER ROLE … SET; the value is a per-session GUC.
# FACE_DB_ENCRYPTION_KEY=

# os/56 P1-4 Pass 2 — Postgres connection for the face_db_pg backend (Cargo
# feature). Distinct from DATABASE_URL (which targets fortress). When unset
# the binary stays on the SQLite path.
# FACE_DB_DATABASE_URL=postgres://face_db:password@localhost:5432/face_db

# ── Alarm grader ─────────────────────────────────────────────────────────────
# Language for alert messages (default: fr)
ALERT_LANG=fr

# nuclear-consul URL for ethical deliberation (default: http://localhost:7710)
CONSUL_URL=http://localhost:7710

# consul backend override (optional)
# CONSUL_BACKEND=http://localhost:7710

# nuclear-chain comms integration (optional)
CHAIN_ENABLED=false
NUCLEAR_CHAIN_URL=http://localhost:9100
NUCLEAR_CHAIN_TOKEN=your-chain-token-here

# Comms bus for alarm notifications (chain-comms, optional)
COMMS_URL=http://localhost:9100
COMMS_API_TOKEN=your-comms-api-token-here
COMMS_ALERT_RECIPIENT=+15551234567

# Actuator agent URL (for automated responses, optional)
# ACTUATOR_URL=http://localhost:8089

# ── Safety Aurelie agent ──────────────────────────────────────────────────────
# Aurelia safety endpoint (canonical name; AURELIE_CHAT_URL also accepted)
AURELIA_SAFETY_URL=http://localhost:8090/api/safety
# AURELIE_CHAT_URL=http://localhost:8090/chat

# ── Telegram notifications ────────────────────────────────────────────────────
# Env var names match the config/security.toml [telegram] section
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# ── Actuator / MQTT ───────────────────────────────────────────────────────────
ACTUATOR_MQTT_HOST=localhost
ACTUATOR_MQTT_PORT=1883
ACTUATOR_MQTT_PREFIX=nuclear/actuator

# ── La Rivière / audit ────────────────────────────────────────────────────────
# Site identifier for La Rivière stream events (optional)
SITE_ID=b450

# Audit log path override (default: /tmp/nuclear-eye-audit.jsonl)
# AUDIT_LOG_PATH=/var/log/nuclear-eye/audit.jsonl

# ── house_runtime only ────────────────────────────────────────────────────────
FORTRESS_BASE_URL=http://127.0.0.1:7710
IDENTITY_BASE_URL=http://127.0.0.1:7720
# HOUSE_JWT_TOKEN is required by house_runtime (no default)
HOUSE_JWT_TOKEN=your-jwt-token-here

# ── nuclear-wrapper sidecar URL (injected by Docker Compose) ──────────────────
NUCLEAR_WRAPPER_URL=http://localhost:9090
